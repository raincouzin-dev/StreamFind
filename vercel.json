{
  "version": 2,
  "builds": [
    { "src": "public/index.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/search", "dest": "/api/search.js" },
    { "src": "/api/trending", "dest": "/api/trending.js" },
    { "src": "/api/providers", "dest": "/api/providers.js" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
